# Onboarding-generated instance config + secrets (per-deployment; never commit).
instance.config.json
.secrets.env
.scribe/
# Per-app generated skill copies (product-specific; per-deployment).
instances/

# Local runtime state — never commit these. They contain real ticket data
# and per-user pipeline history.
pipeline-state.db
pipeline-state.db-shm
pipeline-state.db-wal
pipeline-state.json
pipeline-state.json.migrated
streams/

# Per-user env files. Each teammate creates their own from qa-dashboard.env.example.
.qa-dashboard.env
*.env.local

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/

# Node
node_modules/
dist/
.vite/

# Editor / OS noise
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
/tmp/

# Council Review Gate runtime audit trail — contains usernames + ticket activity.
council-audit.jsonl

# Inter-session hand-off patches; do not commit.
*.patch

# Yarn lockfile — repo standardizes on npm (package-lock.json).
yarn.lock

# uvicorn run log
*.out

# Local Claude tooling — per-machine skill copies + git worktrees, never commit.
.claude/

# Playwright MCP local profile/state.
.playwright-mcp/

# QA test-auth env file — holds Cognito test-login creds. NEVER commit.
.env.qa

# QA evidence is per-run, customer-specific data — NEVER commit it. The live
# dashboard reads it from ~/evidence/ (config.EVIDENCE_DIR); backend/evidence/
# is only a local scratch copy.
backend/evidence/
backend/.qa-screenshots/
backend/automated/

# Ad-hoc QA output dumps dropped at the backend root by manual runs. Not code.
backend/*.png
backend/tc-*.json
backend/tc0*.json
backend/TC-*.json
backend/api-*.json
backend/network-*.json
backend/console-*.json
backend/summary.json
backend/*_REPORT.md
backend/QA_EVIDENCE_*.md
backend/FINAL_QA_SUMMARY.md
backend/HANDOFF_*.md

# QA evidence + test output (regenerated; never commit — see docs plan 2026-06-29)
evidence/
frontend/test-results/
backend/index.html
