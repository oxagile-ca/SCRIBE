# Per-user config for qa-dashboard. Copy to ~/.qa-dashboard.env and edit.
# setup.sh writes one of these for you the first time you run it.

# Jira credentials. Token from https://id.atlassian.com/manage-profile/security/api-tokens
# Email is the one your Atlassian account is registered to.
JIRA_EMAIL=your.name@example.com
JIRA_TOKEN=replace-me

# Your Deploy envs, comma-separated. Each teammate gets their own proj-<name>-* set.
# Order matters — the first one is treated as the default for auto-pick.
QA_DASH_ENVS=qa-env,qa-env-1,qa-env-2,qa-env-3

# Optional: explicitly pin the default. Otherwise QA_DASH_ENVS[0] is used.
# QA_DASH_DEFAULT_ENV=qa-env

# Optional: override the Claude Code session dir if your install is non-standard.
# QA_DASH_SESSION_DIR=~/.claude/projects/-Users-your-name
